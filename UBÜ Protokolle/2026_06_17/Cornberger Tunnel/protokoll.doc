    .red ul{margin:0 0 0 18pt;padding-left:0;}
    .red li{margin:0 0 3pt 0;font-family:Arial,Helvetica,sans-serif;font-size:11pt;line-height:115%;mso-line-height-rule:auto;}
    h2{font-family:Arial,Helvetica,sans-serif;font-size:14pt;font-weight:bold;page-break-after:avoid;margin:0 0 8pt 0;line-height:1.2;text-align:left;}
