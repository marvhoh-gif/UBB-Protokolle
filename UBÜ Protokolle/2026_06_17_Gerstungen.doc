      <tr><td><b>Datum/Zeit:</b></td><td>2026-06-17 14:52</td></tr>
      <tr><td><b>Ort/Raum/Strecke:</b></td><td></td></tr>
      <tr><td><b>Anwesende/Teilnehmer:</b></td><td>Marvin Hohmann</td></tr>
      <tr><td><b>Witterung bei Begehung:</b></td><td>23 °C, bedeckt, trocken, Wind 12 km/h</td></tr>
      <tr><td><b>Protokollführung:</b></td><td>Marvin Hohmann</td></tr>
      <tr><td><b>Bemerkung:</b></td><td></td></tr>
