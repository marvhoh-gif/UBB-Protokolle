    h4{font-family:Arial,Helvetica,sans-serif;font-size:11pt;font-weight:bold;page-break-after:avoid;margin:10pt 0 5pt 0;line-height:1.2;text-align:left;}
    h4.finding-heading{font-weight:normal;text-decoration:underline;}
    table.header-table{width:100%!important;border:0!important;border-collapse:collapse!important;margin:0!important;}
